        "LIN02": "lineItems[].productIdQualifier",
        "LIN03": "lineItems[].productId"
      }
    },
    {
      "tag": "SN1",
      "purpose": "item_shipment_detail",
      "required": false,
      "max": 100000,
      "loop": "lineItems",
      "maps": {
        "SN102": "lineItems[].quantityShipped",
        "SN103": "lineItems[].unitOfMeasure"
      }
    },
    {
      "tag": "CTT",
      "purpose": "transaction_summary",
      "required": false,
      "max": 1,
      "maps": {
        "CTT01": "summary.lineItemCount"
      }
    }
