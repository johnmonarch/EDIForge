        "REF02": "references[].value"
      }
    },
    {
      "tag": "N1",
      "purpose": "parties",
      "required": false,
      "max": 20,
      "loop": "parties",
      "maps": {
        "N101": "parties[].role",
        "N102": "parties[].name",
        "N103": "parties[].idQualifier",
        "N104": "parties[].id"
      }
    },
    {
      "tag": "N3",
      "purpose": "party_address_lines",
